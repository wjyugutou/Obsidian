properties:
  note.created:
    displayName: created
views:
  - type: table
    name: 表格
    filters:
      and:
        - file.ext != "base"
    order:
      - file.name
      - tags
      - updated
    sort:
      - property: created
        direction: ASC
      - property: file.name
        direction: ASC
      - property: tags
        direction: ASC
